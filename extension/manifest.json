{
  "manifest_version": 3,
  "name": "Remote Browser Bridge",
  "version": "1.16.0",
  "description": "让 CodeNext 通过 HTTP 长轮询远程操控此浏览器，仅操控名为 Remote Control 的标签组",
  "permissions": [
    "activeTab",
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "alarms",
    "webNavigation",
    "cookies"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Remote Browser Bridge"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["canvas-hook.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
